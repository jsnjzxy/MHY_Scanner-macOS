{
  "version": 3,
  "configurePresets": [
    {
      "name": "macos-base",
      "description": "macOS 基础配置",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/${presetName}_build",
      "cacheVariables": {
        "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_OBJCXX_STANDARD": "23",
        "CMAKE_AUTOUIC": "ON",
        "CMAKE_AUTOMOC": "ON",
        "CMAKE_AUTORCC": "ON",
        "CMAKE_MAKE_PROGRAM": "ninja"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-vcpkg-base",
      "description": "macOS with vcpkg 基础配置",
      "hidden": true,
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    },
    {
      "name": "macos-vcpkg-ci",
      "description": "macOS CI 构建配置（使用已安装的 vcpkg 包）",
      "hidden": true,
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{VCPKG_INSTALLED_DIR}/arm64-osx",
        "CMAKE_FIND_ROOT_PATH": "$env{VCPKG_INSTALLED_DIR}/arm64-osx"
      }
    },
    {
      "name": "Debug",
      "displayName": "Debug",
      "description": "macOS 调试构建 (vcpkg)",
      "inherits": "macos-vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "Release",
      "displayName": "Release",
      "description": "macOS 发布构建 (vcpkg)",
      "inherits": "macos-vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "RelWithDebInfo",
      "displayName": "RelWithDebInfo",
      "description": "macOS 带调试信息的发布构建 (vcpkg)",
      "inherits": "macos-vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "Debug-CI",
      "displayName": "Debug (CI)",
      "description": "macOS 调试构建 (CI, 使用已安装包)",
      "inherits": "macos-vcpkg-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "Release-CI",
      "displayName": "Release (CI)",
      "description": "macOS 发布构建 (CI, 使用已安装包)",
      "inherits": "macos-vcpkg-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Debug",
      "displayName": "Debug",
      "configurePreset": "Debug",
      "configuration": "Debug"
    },
    {
      "name": "Release",
      "displayName": "Release",
      "configurePreset": "Release",
      "configuration": "Release"
    },
    {
      "name": "RelWithDebInfo",
      "displayName": "RelWithDebInfo",
      "configurePreset": "RelWithDebInfo",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "Debug-CI",
      "displayName": "Debug (CI)",
      "configurePreset": "Debug-CI",
      "configuration": "Debug"
    },
    {
      "name": "Release-CI",
      "displayName": "Release (CI)",
      "configurePreset": "Release-CI",
      "configuration": "Release"
    }
  ]
}
