{
  "version": 3,
  "configurePresets": [
    {
      "name": "macos-base",
      "description": "macOS 基础配置",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build",
      "installDir": "${sourceDir}/build/install",
      "cacheVariables": {
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.0",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_PREFIX_PATH": "/opt/homebrew;/usr/local",
        "INSTALL_GTEST": false,
        "DEV": true,
        "MHY_SCAN_PLATFORM": "macOS"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-vcpkg-base",
      "description": "macOS with vcpkg 基础配置",
      "hidden": true,
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    },
    {
      "name": "Debug",
      "displayName": "Debug",
      "description": "macOS 调试构建 (vcpkg)",
      "inherits": "macos-vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "Release",
      "displayName": "Release",
      "description": "macOS 发布构建 (vcpkg)",
      "inherits": "macos-vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "RelWithDebInfo",
      "displayName": "RelWithDebInfo",
      "description": "macOS 带调试信息的发布构建 (vcpkg)",
      "inherits": "macos-vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Debug",
      "displayName": "Debug",
      "configurePreset": "Debug",
      "configuration": "Debug"
    },
    {
      "name": "Release",
      "displayName": "Release",
      "configurePreset": "Release",
      "configuration": "Release"
    },
    {
      "name": "RelWithDebInfo",
      "displayName": "RelWithDebInfo",
      "configurePreset": "RelWithDebInfo",
      "configuration": "RelWithDebInfo"
    }
  ]
}
