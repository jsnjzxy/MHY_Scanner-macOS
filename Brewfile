# Brewfile for MHY_Scanner macOS build
# 使用: brew bundle --file=Brewfile --verbose
#
# 注意: 本项目使用 vcpkg 管理大部分依赖库 (Qt, OpenCV, FFmpeg, cURL, OpenSSL 等)
# Brewfile 仅管理构建工具和系统级依赖

# ========================================
# 构建工具
# ========================================

# CMake (构建系统)
brew "cmake"

# Ninja (更快的构建)
brew "ninja"

# pkg-config (库查找)
brew "pkg-config"

# ========================================
# DMG 打包工具
# ========================================

# create-dmg (创建漂亮的 DMG 镜像)
brew "create-dmg"

# ========================================
# vcpkg 构建所需的 autotools 工具
# ========================================

# autoconf (自动配置工具)
brew "autoconf"

# automake (自动化 Makefile 生成)
brew "automake"

# libtool (编译库的工具)
brew "libtool"

